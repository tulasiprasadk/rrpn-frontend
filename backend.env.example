# Copy this file to backend.env and fill the values. DO NOT COMMIT backend.env

# Backend server
PORT=3000
BACKEND_URL=https://api.example.com
SESSION_SECRET=replace-with-a-strong-session-secret
DATABASE_URL=postgres://postgres:postgres@db:5432/rrn
DB_SSL=false

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Frontend URL used for OAuth redirects
FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com,https://www.example.com

# Frontend build-time API URLs
VITE_API_URL=https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
VITE_GOOGLE_MAPS_API_KEY=replace-with-your-google-maps-browser-key

# JWT signing secret
JWT_SECRET=replace-with-a-strong-secret
